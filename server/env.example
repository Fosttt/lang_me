# copy to .env and fill in
LANGME_TOKEN=change-me-long-random-string
LANGME_MODEL=haiku
LANGME_TIMEOUT=60
# LANGME_CLAUDE_BIN=/root/.local/bin/claude
# Долгоживущий токен подписки (claude setup-token) — надёжнее, чем копия
# ~/.claude/.credentials.json, которая протухает при ротации refresh-токена:
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
