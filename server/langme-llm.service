# systemd unit for the LangMe LLM proxy.
# Install:
#   sudo cp langme-llm.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now langme-llm
[Unit]
Description=LangMe LLM proxy (claude -p haiku)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/lang_me/server
EnvironmentFile=/root/lang_me/server/.env
# TLS: самоподписанный сертификат, приложение пиннит его по SHA-256.
# Генерация: openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
#   -keyout certs/key.pem -out certs/cert.pem -days 3650 -nodes \
#   -subj "/CN=<IP>" -addext "subjectAltName=IP:<IP>"
ExecStart=/root/lang_me/server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8977 --ssl-keyfile /root/lang_me/server/certs/key.pem --ssl-certfile /root/lang_me/server/certs/cert.pem
Restart=on-failure
RestartSec=5
# claude CLI needs HOME to find its login
Environment=HOME=/root

[Install]
WantedBy=multi-user.target
